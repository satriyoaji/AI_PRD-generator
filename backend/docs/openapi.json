    "/api/transcript": {
      "post": {
        "description": "Creates a transcript by uploading a plain text `.txt` file or WebVTT `.vtt` file. The uploaded file must be sent as multipart form-data using the `content` file field. The file body is read and stored as a text string.",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "properties": {
                  "content": {
                    "description": "Required uploaded transcript file. Permitted file extensions: `.txt`, `.vtt`.",
                    "format": "binary",
                    "type": "string"
                  },
                  "title": {
                    "description": "Optional transcript title.",
                    "example": "Q1 Planning Meeting",
                    "type": "string"
                  }
                },
                "required": [
                  "content"
                ],
                "type": "object"
              }
            }
          },
          "description": "Multipart form with optional `title` text field and required `content` file field. Only `.txt` and `.vtt` file extensions are permitted.",
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "example": {
                  "content": "WEBVTT\n\n00:00:00.000 --\u003e 00:00:05.000\nWe need a dashboard for product managers.",
                  "created_at": "2026-06-06T10:30:00Z",
                  "id": "2f4fb8e8-8b51-47d0-b699-3fc2d64c6f2d",
                  "title": "Q1 Planning Meeting"
                },
                "schema": {
                  "$ref": "#/components/schemas/Transcript"
                }
              }
            },
            "description": "Created transcript. `content` contains the uploaded file contents converted to a string."
          },
          "400": {
            "content": {
              "application/json": {
                "example": {
                  "error": "Missing file, empty file, or malformed multipart request."
                },
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Missing file, empty file, or malformed multipart request."
          },
          "415": {
            "content": {
              "application/json": {
                "example": {
                  "error": "Uploaded file extension is not `.txt` or `.vtt`."
                },
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Uploaded file extension is not `.txt` or `.vtt`."
          },
          "500": {
            "content": {
              "application/json": {
                "example": {
                  "error": "Failed to read or save transcript."
                },
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Failed to read or save transcript."
          }
        },
        "summary": "Create transcript from uploaded file",
        "tags": [
          "Transcripts"
        ]
      }
    },
