                "example": {
                  "content": {
                    "content": "# Functional Requirements\n\n1. The system shall display dashboard metrics."
                  },
                  "created_at": "2026-06-06T10:33:00Z",
                  "id": "a260d2d4-d2aa-4e55-8765-51d1530748af",
                  "transcript_id": "2f4fb8e8-8b51-47d0-b699-3fc2d64c6f2d",
                  "type": "requirements"
                },
                "schema": {
                  "$ref": "#/components/schemas/Generation"
                }
              }
            },
            "description": "Generated functional requirements."
          },
          "400": {
            "content": {
              "application/json": {
                "example": {
                  "error": "Invalid request body."
                },
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Invalid request body."
          },
          "404": {
            "content": {
              "application/json": {
                "example": {
                  "error": "Transcript not found."
                },
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Transcript not found."
          },
          "500": {
            "content": {
              "application/json": {
                "example": {
                  "error": "Failed to generate requirements."
                },
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Failed to generate requirements."
          }
        },
        "summary": "Generate functional requirements",
        "tags": [
          "Generation"
        ]
      }
    },
