{
  "components": {
    "schemas": {
      "ErrorResponse": {
        "properties": {
          "error": {
            "type": "string"
          }
        },
        "required": [
          "error"
        ],
        "type": "object"
      },
      "GenerateRequest": {
        "properties": {
          "transcript_id": {
            "format": "uuid",
            "type": "string"
          }
        },
        "required": [
          "transcript_id"
        ],
        "type": "object"
      },
      "Generation": {
        "properties": {
          "content": {
            "additionalProperties": true,
            "type": "object"
          },
          "created_at": {
            "format": "date-time",
            "type": "string"
          },
          "id": {
            "format": "uuid",
            "type": "string"
          },
          "transcript_id": {
            "format": "uuid",
            "type": "string"
          },
          "type": {
            "enum": [
              "prd",
              "stories",
              "requirements",
              "wireframe"
            ],
            "type": "string"
          }
        },
        "required": [
          "id",
          "transcript_id",
          "type",
          "content",
          "created_at"
        ],
        "type": "object"
      },
      "HealthResponse": {
        "properties": {
          "service": {
            "example": "prd-generator-api",
            "type": "string"
          },
          "status": {
            "example": "healthy",
            "type": "string"
          }
        },
        "required": [
          "status",
          "service"
        ],
        "type": "object"
      },
      "HistoryItem": {
        "properties": {
          "created_at": {
            "format": "date-time",
            "type": "string"
          },
          "id": {
            "format": "uuid",
            "type": "string"
          },
          "transcript_id": {
            "format": "uuid",
            "type": "string"
          },
          "transcript_title": {
            "type": "string"
          },
          "type": {
            "enum": [
              "prd",
              "stories",
              "requirements",
              "wireframe"
            ],
            "type": "string"
          }
        },
        "required": [
          "id",
          "transcript_id",
          "transcript_title",
          "type",
          "created_at"
        ],
        "type": "object"
      },
      "HistoryResponse": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/HistoryItem"
            },
            "type": "array"
          }
        },
        "required": [
          "items"
        ],
        "type": "object"
      },
      "Transcript": {
        "properties": {
          "content": {
            "description": "Uploaded transcript file contents converted to a text string.",
            "type": "string"
          },
          "created_at": {
            "format": "date-time",
            "type": "string"
          },
          "id": {
            "format": "uuid",
            "type": "string"
          },
          "title": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "title",
          "content",
          "created_at"
        ],
        "type": "object"
      }
    }
  },
  "info": {
    "description": "API contracts for the AI Product Requirement \u0026 UI Generator backend.",
    "title": "AI PRD Generator API",
    "version": "1.0.0"
  },
  "openapi": "3.0.3",
  "paths": {
    "/api/generate/prd": {
      "post": {
        "description": "Generates a Product Requirements Document from a transcript.",
        "requestBody": {
          "content": {
            "application/json": {
              "example": {
                "transcript_id": "2f4fb8e8-8b51-47d0-b699-3fc2d64c6f2d"
              },
              "schema": {
                "$ref": "#/components/schemas/GenerateRequest"
              }
            }
          },
          "description": "JSON body containing the transcript ID.",
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "example": {
                  "content": {
                    "content": "# Product Requirements Document\n\n## Overview\nBuild a dashboard for product managers."
                  },
                  "created_at": "2026-06-06T10:31:00Z",
                  "id": "b6a0ce5a-a43f-414f-83b4-8a908739bcfb",
                  "transcript_id": "2f4fb8e8-8b51-47d0-b699-3fc2d64c6f2d",
                  "type": "prd"
                },
                "schema": {
                  "$ref": "#/components/schemas/Generation"
                }
              }
            },
            "description": "Generated PRD content."
          },
          "400": {
            "content": {
              "application/json": {
                "example": {
                  "error": "Invalid request body."
                },
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Invalid request body."
          },
          "404": {
            "content": {
              "application/json": {
                "example": {
                  "error": "Transcript not found."
                },
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Transcript not found."
          },
          "500": {
            "content": {
              "application/json": {
                "example": {
                  "error": "Failed to generate PRD."
                },
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Failed to generate PRD."
          }
        },
        "summary": "Generate PRD",
        "tags": [
          "Generation"
        ]
      }
    },
    "/api/generate/requirements": {
