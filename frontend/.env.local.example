# ─────────────────────────────────────────────────────────────────
# Frontend environment variables — copy this file to .env.local
# and fill in real values. .env.local is git-ignored; this file
# (.env.local.example) is safe to commit.
# ─────────────────────────────────────────────────────────────────

# Base URL of the Go backend API (no trailing slash).
# • Local development  → http://localhost:8080
# • Staging/production → https://your-backend.railway.app
#
# Must be prefixed with NEXT_PUBLIC_ so Next.js exposes it to the
# browser bundle. Changing this requires a dev-server restart.
NEXT_PUBLIC_API_URL=http://localhost:8080
