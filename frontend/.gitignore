# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── Dependencies ─────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js build output ─────────────────────────────────────────
/.next/
/out/
/build

# ── Testing ──────────────────────────────────────────────────────
/coverage

# ── Environment / secrets ────────────────────────────────────────
# Local overrides — contain real secrets, never commit
.env.local
.env.*.local

# Other .env files with potential secrets
.env.development.local
.env.test.local
.env.production.local

# Generic .env (if used) — opt-in to commit by removing this line
.env

# .env.local.example IS committed (safe template, no real values)

# ── Vercel ───────────────────────────────────────────────────────
.vercel

# ── TypeScript ───────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── OS / editor noise ────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem
.idea/
.vscode/
*.swp
*.swo

# ── Debug logs ───────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
